{
  "name": "crow-knight",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "setup:python": "python3 -m venv .venv && .venv/bin/python -m pip install -r requirements.txt",
    "dev": ".venv/bin/python tools/dev_server.py",
    "dev:5500": ".venv/bin/python tools/dev_server.py --port 5500",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check": "npm run lint && prettier --check .",
    "clip:preview": ".venv/bin/python tools/clip_preview_watcher.py --once",
    "clip:watch": ".venv/bin/python tools/clip_preview_watcher.py"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4"
  }
}
